# Grafana Helm values
adminUser: {{ grafana_admin_user }}
adminPassword: {{ grafana_admin_password }}

persistence:
  enabled: {{ grafana_storage_enabled | lower }}
  size: {{ grafana_storage_size }}

resources:
  requests:
    cpu: 100m
    memory: 256Mi
  limits:
    cpu: 500m
    memory: 512Mi

# Ingress configuration
ingress:
  enabled: {{ grafana_ingress_enabled | lower }}
  ingressClassName: {{ grafana_ingress_class }}
  hosts:
    - {{ grafana_hostname }}
{% if grafana_tls_enabled %}
  tls:
    - secretName: grafana-tls
      hosts:
        - {{ grafana_hostname }}
  annotations:
    cert-manager.io/cluster-issuer: {{ grafana_cluster_issuer }}
{% endif %}

# Pre-configure data sources
datasources:
  datasources.yaml:
    apiVersion: 1
    datasources:
      - name: Prometheus
        type: prometheus
        url: {{ grafana_prometheus_url }}
        access: proxy
        isDefault: true
        editable: false
      - name: Loki
        type: loki
        url: {{ grafana_loki_url }}
        access: proxy
        editable: false

# Pre-install useful dashboards
dashboardProviders:
  dashboardproviders.yaml:
    apiVersion: 1
    providers:
      - name: 'default'
        orgId: 1
        folder: ''
        type: file
        disableDeletion: false
        editable: true
        options:
          path: /var/lib/grafana/dashboards/default

dashboards:
  default:
    # Kubernetes cluster monitoring
    kubernetes-cluster:
      gnetId: 6417
      revision: 1
      datasource: Prometheus
    # Node exporter full
    node-exporter:
      gnetId: 1860
      revision: 37
      datasource: Prometheus
    # Kubernetes pods
    kubernetes-pods:
      gnetId: 6781
      revision: 1
      datasource: Prometheus

# Enable sidecar for dashboard discovery
sidecar:
  dashboards:
    enabled: true
  datasources:
    enabled: true
